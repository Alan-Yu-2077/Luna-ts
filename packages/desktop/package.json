{
  "name": "@luna/desktop",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Alan-Yu-2077/Luna-ts.git", "directory": "packages/desktop" },
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for Luna (Initiative 19) — spawns the compiled luna-server sidecar and serves the packages/web production build over a pinned loopback origin",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "bun build src/main.ts --target=node --format=cjs --external=electron --outfile=dist/main.cjs && bun build src/preload.ts --target=node --format=cjs --external=electron --outfile=dist/preload.cjs && bun build src/smoke.ts --target=node --format=cjs --external=electron --outfile=dist/smoke.cjs",
    "compile:server": "bun build --compile ../server/src/main.ts --outfile bin/luna-server",
    "compile:server:win": "bun build --compile --target=bun-windows-x64 ../server/src/main.ts --outfile bin/luna-server.exe",
    "start": "bun run build && electron .",
    "smoke": "bun run build && electron dist/smoke.cjs",
    "pack": "bun run build && electron-builder --dir",
    "fetch:7zr": "bun scripts/fetch-7zr.ts",
    "pack:win": "bun run fetch:7zr && bun run build && electron-builder --win",
    "smoke:packaged": "LUNA_SMOKE=1 release/mac-arm64/Luna.app/Contents/MacOS/Luna"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.luna.desktop",
    "productName": "Luna",
    "directories": {
      "output": "release"
    },
    "files": ["dist/main.cjs", "dist/preload.cjs", "package.json"],
    "extraResources": [
      { "from": "../server/src/migrations", "to": "migrations" },
      { "from": "../server/persona", "to": "persona" },
      { "from": "../web/dist", "to": "web" }
    ],
    "mac": {
      "target": [{ "target": "dir", "arch": ["arm64"] }],
      "icon": "build/icon.icns",
      "identity": null,
      "extraResources": [{ "from": "bin/luna-server", "to": "luna-server" }],
      "extendInfo": {
        "NSLocationUsageDescription": "Luna uses your location to show local weather.",
        "NSLocationWhenInUseUsageDescription": "Luna uses your location to show local weather."
      }
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "extraResources": [
        { "from": "bin/luna-server.exe", "to": "luna-server.exe" },
        { "from": "bin/7zr.exe", "to": "7zr.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
